PORT=8787
AUTO_CONNECT=true

# v038 部署模式：local=本機開發，cloud=雲端API外殼，不強制本機Chrome
DEPLOY_MODE=local
# offline | node_ws | local_chrome | cloud_browser
CAPTURE_SOURCE=local_chrome
PUBLIC_FRONTEND_ORIGIN=http://127.0.0.1:5174
CLOUD_BROWSER_URL=https://cloud-worker.example/snapshot
CLOUD_CAPTURE_POLL_MS=2000

MT_ORIGIN=https://gsa.ofalive99.net
MT_PING_INTERVAL_MS=5000

# Chrome背景抓取模式：貼完整 MT token 網址。只放 backend/proxy，不放 frontend。
CHROME_CAPTURE_URL=https://gsa.ofalive99.net/?token=請填入你的MT_TOKEN&lang=zhtw
CHROME_CDP_PORT=9226
CHROME_HEADLESS=false

# Node 直連模式保留，但目前可能被 MT 403。只放 backend/proxy。
MT_TOKEN=請填入你的MT_TOKEN

# Supabase 線上核心/記憶中心：後端專用，請勿填在 frontend。
SUPABASE_URL=https://gscfexhsqxvtpyxudtza.supabase.co
SUPABASE_SERVICE_ROLE_KEY=請填入後端專用SUPABASE_SERVICE_ROLE_KEY
# 若暫時沒有 service role，也可在本機/後端使用 Database Pooler URI；仍然只能放 backend/proxy。
SUPABASE_DB_CONNECTION_STRING=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
